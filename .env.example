ENVIRONMENT=development

APP_NAME=Arcanum
APP_DEBUG=true
APP_KEY=base64:
APP_URL=http://localhost

# Show "suggestion" hints in error responses (e.g. "did you mean X?",
# "registered services are A, B, C"). Defaults to APP_DEBUG when unset.
# Set independently if you want suggestions in production for staging
# environments, or off in development for cleaner error pages.
APP_VERBOSE_ERRORS=true

# Framework cache master switch.
# Set to false to disable every framework-internal cache (templates, helpers,
# page discovery, middleware discovery, configuration). Use while iterating
# on templates and config when you want a fresh pull on every refresh.
# Independent of APP_DEBUG.
APP_FRAMEWORK_CACHE=true
